# EggbotWireless-rescue_+3.3V-power
#
DEF EggbotWireless-rescue_+3.3V-power #PWR 0 0 Y Y 1 F P
F0 "#PWR" 0 -150 50 H I C CNN
F1 "EggbotWireless-rescue_+3.3V-power" 0 140 50 H V C CNN
